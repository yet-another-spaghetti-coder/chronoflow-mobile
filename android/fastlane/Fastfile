require 'base64'

default_platform(:android)

platform :android do
  desc "Deploy a new version to the Google Play Internal Track"
  lane :deploy do
    # 1. Validate required environment variables
    required_env_vars = {
      'ANDROID_KEYSTORE_BASE64' => 'Base64 encoded Android keystore',
      'STORE_PASSWORD' => 'Keystore password',
      'KEY_ALIAS' => 'Key alias',
      'KEY_PASSWORD' => 'Key password',
      'PLAY_STORE_SA_JSON' => 'Play Store service account JSON'
    }
    
    required_env_vars.each do |var, description|
      if ENV[var].to_s.empty?
        UI.user_error!("ENV['#{var}'] is missing! (#{description})")
      end
    end

    # 2. Define temporary paths
    keystore_path = File.expand_path("/tmp/upload_keystore_#{Time.now.to_i}_#{rand(1_000_000)}.jks")
    key_properties_path = File.expand_path("key.properties")

    begin
      # 3. Decode the Keystore
      File.open(keystore_path, 'wb') do |f|
        f.write(Base64.decode64(ENV['ANDROID_KEYSTORE_BASE64']))
      end
      File.chmod(0600, keystore_path)

      # 4. Write a temporary key.properties file for Flutter's build.gradle
      File.write(key_properties_path, <<~PROPS
        storeFile=#{keystore_path}
        storePassword=#{ENV['STORE_PASSWORD']}
        keyAlias=#{ENV['KEY_ALIAS']}
        keyPassword=#{ENV['KEY_PASSWORD']}
      PROPS
      )

      # 5. Execute Flutter CLI to build the App Bundle (AAB) with obfuscation
      Dir.chdir("..") do
        sh("flutter build appbundle --release --obfuscate --split-debug-info=./debug_info")
      end

      # 6. Upload to Play Store (Internal Track)
      upload_to_play_store(
        track: "internal",
        release_status: "draft",
        json_key_data: ENV['PLAY_STORE_SA_JSON'],
        aab: "../build/app/outputs/bundle/release/app-release.aab"
      )
    ensure
      # 7. Cleanup
      File.delete(keystore_path) if File.exist?(keystore_path)
      File.delete(key_properties_path) if File.exist?(key_properties_path)
    end
  end
end